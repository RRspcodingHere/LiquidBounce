var scriptName = "AutoWindBreeze";
var scriptAuthor = "Helper";
var scriptVersion = 1.2;

function AutoWindBreeze() {
    var minDelay = value.createInteger("MinDelay", 40, 0, 300);
    var maxDelay = value.createInteger("MaxDelay", 120, 0, 300);
    var pitchSpeed = value.createFloat("PitchSpeed", 12.0, 5.0, 30.0);
    var jitter = value.createFloat("Jitter", 3.0, 0.0, 10.0);
    
    var lastExecution = 0;
    var active = false;

    this.getName = function() { return "AutoWindBreeze"; }
    this.getCategory = function() { return "Movement"; }

    this.onUpdate = function() {
        if (mc.thePlayer.onGround) {
            active = false;
            return;
        }

        if (mc.thePlayer.fallDistance > 0.15 && !active) {
            var slot = this.getSlot();
            if (slot === -1) return;

            var targetPitch = 90.0 - (Math.random() * jitter.get());
            
            if (mc.thePlayer.rotationPitch < targetPitch) {
                mc.thePlayer.rotationPitch = Math.min(targetPitch, mc.thePlayer.rotationPitch + pitchSpeed.get());
            }

            var now = System.currentTimeMillis();
            var delay = minDelay.get() + Math.random() * (maxDelay.get() - minDelay.get());

            if (mc.thePlayer.rotationPitch >= (targetPitch - 5.0) && (now - lastExecution) > delay) {
                var prevSlot = mc.thePlayer.inventory.currentItem;
                
                mc.thePlayer.inventory.currentItem = slot;
                mc.playerController.sendUseItem(mc.thePlayer, mc.theWorld, mc.thePlayer.inventory.getStackInSlot(slot));
                mc.thePlayer.inventory.currentItem = prevSlot;
                
                lastExecution = now;
                active = true;
            }
        }
    }

    this.getSlot = function() {
        for (var i = 0; i < 9; i++) {
            var item = mc.thePlayer.inventory.getStackInSlot(i);
            if (item != null && item.getItem().getUnlocalizedName().toLowerCase().contains("wind_charge")) return i;
        }
        return -1;
    }

    this.addValues(minDelay, maxDelay, pitchSpeed, jitter);
}

var autoWindBreeze = new AutoWindBreeze();
var instance;

function onEnable() {
    instance = moduleManager.registerModule(autoWindBreeze);
}

function onDisable() {
    moduleManager.unregisterModule(instance);
}


